{
  "expo": {
    "name": "mangaEasy",
    "slug": "mangaEasy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-manga-easy.png",
    "scheme": "mangaeasy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon-manga-easy.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#13111C",
        "foregroundImage": "./assets/images/icon-manga-easy-adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.herudegas.mangaEasy",
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon-manga-easy.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/icon-manga-easy.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
